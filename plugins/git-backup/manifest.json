{
  "id": "git-backup",
  "name": "Git Backup",
  "version": "1.0.0",
  "description": "Automatic git backup with commit history and version control",
  "author": "Mnemo",
  "minMnemoVersion": "2.0.0",
  "tags": ["backup", "git", "version-control"],
  "icon": "git-branch",
  "server": "server/index.js",
  "client": "client/index.js",
  "settings": [
    {
      "key": "autoCommitInterval",
      "type": "number",
      "default": 5,
      "label": "Auto-commit interval (minutes, 0 to disable)",
      "perUser": false
    },
    {
      "key": "commitMessage",
      "type": "string",
      "default": "auto-backup: {{date}}",
      "label": "Commit message template",
      "perUser": false
    }
  ]
}
